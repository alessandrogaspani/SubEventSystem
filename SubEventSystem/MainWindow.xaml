<Window x:Class="SubEventSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SubEvent - Sensor Monitor" Height="500" Width="600"
        Background="#1e1e2e" Closed="Window_Closed">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header: Producer controls -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <Button x:Name="BtnStart" Content="▶ Start" Click="BtnStart_Click"
                    Padding="12,6" Background="#FF000F" Foreground="White" 
                    BorderThickness="0" FontWeight="Bold" Margin="0,0,8,0"/>
            <Button x:Name="BtnStop" Content="⏹ Stop" Click="BtnStop_Click"
                    Padding="12,6" Background="#6764f6" Foreground="White" 
                    BorderThickness="0" FontWeight="Bold" Margin="0,0,20,0"/>
            <Ellipse x:Name="ProducerLed" Width="12" Height="12" 
                     Fill="Gray" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock x:Name="TxtProducerState" Text="Stopped" 
                       Foreground="#aaa" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Widgets -->
        <UniformGrid Grid.Row="1" Columns="2" Margin="0,0,0,15">
            <!-- Temperature Widget -->
            <Border Background="#2e2e3e" CornerRadius="8" Padding="15" Margin="5">
                <StackPanel>
                    <DockPanel>
                        <TextBlock Text="🌡 Temperature" Foreground="White" 
                                   FontWeight="SemiBold" DockPanel.Dock="Left"/>
                        <CheckBox x:Name="ChkTemp" IsChecked="True" 
                                  Checked="ChkTemp_Changed" Unchecked="ChkTemp_Changed"
                                  DockPanel.Dock="Right" HorizontalAlignment="Right"/>
                    </DockPanel>
                    <TextBlock x:Name="TxtTemp" Text="-- °C" FontSize="28" 
                               FontWeight="Bold" Foreground="#ff957e" 
                               HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <!-- Pressure Widget -->
            <Border Background="#2e2e3e" CornerRadius="8" Padding="15" Margin="5">
                <StackPanel>
                    <DockPanel>
                        <TextBlock Text="💨 Pressure" Foreground="White" 
                                   FontWeight="SemiBold" DockPanel.Dock="Left"/>
                        <CheckBox x:Name="ChkPressure" IsChecked="True" 
                                  Checked="ChkPressure_Changed" Unchecked="ChkPressure_Changed"
                                  DockPanel.Dock="Right" HorizontalAlignment="Right"/>
                    </DockPanel>
                    <TextBlock x:Name="TxtPressure" Text="-- hPa" FontSize="28" 
                               FontWeight="Bold" Foreground="#93a1ff" 
                               HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Event Log -->
        <Border Grid.Row="2" Background="#2e2e3e" CornerRadius="8" Padding="10" Margin="5">
            <DockPanel>
                <TextBlock Text="📋 Event Log" Foreground="White" FontWeight="SemiBold" 
                           DockPanel.Dock="Top" Margin="0,0,0,8"/>
                <ListBox x:Name="LstLog" Background="Transparent" BorderThickness="0"
                         Foreground="#ccc" FontSize="11" FontFamily="Consolas"/>
            </DockPanel>
        </Border>

        <!-- Footer: Active listeners -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="5,10,0,0">
            <Ellipse x:Name="ListenersLed" Width="10" Height="10" 
                     Fill="Gray" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock x:Name="TxtActiveListeners" Text="Active listeners: 0/2" 
                       Foreground="#aaa" VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
